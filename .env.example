# ============================================================
# 服务端密钥（不要使用 VITE_ 前缀，避免打进浏览器包）
# 复制为 .env 后填写。.env 已被 gitignore。
# ============================================================

# 高德 Web 服务 Key（IP 定位 / 地理编码 / 实时天气）
# 控制台需开通：IP定位、地理编码、天气查询
# https://console.amap.com/dev/key/app
AMAP_KEY=

# 彩云天气 Token（实时空气质量）
# https://dashboard.caiyunapp.com/
CAIYUN_TOKEN=

# WAQI Token（备用 AQI；可用 demo）
# https://aqicn.org/data-platform/token/
WAQI_TOKEN=demo

# ------------------------------------------------------------
# 说明：
# 1. 前端只请求同源 /api/*，密钥永不进浏览器包。
# 2. 本地：Vite 开发/预览代理读取本文件注入。
# 3. Vercel：Project → Settings → Environment Variables
#    写入 AMAP_KEY / CAIYUN_TOKEN / WAQI_TOKEN（Production + Preview）
#    Edge 函数见 /api/* → server/proxy.mjs
# 4. Cloudflare Pages：Settings → Environment variables
#    同上三个变量；Functions 见 /functions/api/*
# 5. 切勿把真实 key 写进 README、截图或提交到 git。
# ------------------------------------------------------------
