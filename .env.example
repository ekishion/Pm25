# ============================================================
# 服务端密钥（不要使用 VITE_ 前缀，避免打进浏览器包）
# 复制为 .env 后填写。.env 已被 gitignore。
# ============================================================

# 高德 Web 服务 Key（IP 定位）
# https://console.amap.com/dev/key/app
AMAP_KEY=

# 彩云天气 Token（实时空气质量）
# https://dashboard.caiyunapp.com/
CAIYUN_TOKEN=

# WAQI Token（备用 AQI；可用 demo）
# https://aqicn.org/data-platform/token/
WAQI_TOKEN=demo

# ------------------------------------------------------------
# 说明：
# 1. 前端只请求同源 /api/*，密钥由 Vite 开发/预览代理注入。
# 2. 生产静态托管若无反向代理，请仅依赖公开源（Open-Meteo），
#    或在网关层配置与 vite.config.js 相同的 /api 转发。
# 3. 切勿把真实 key 写进 README、截图或提交到 git。
# ------------------------------------------------------------
