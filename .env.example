# ============================================================
# 服务端密钥（不要使用 VITE_ 前缀，避免打进浏览器包）
# 复制为 .env 后填写。.env 已被 gitignore。
# ============================================================

# 高德 Web 服务 Key（IP 定位 / 地理编码 / 实时天气）
# 控制台需开通：IP定位、地理编码、天气查询
# https://console.amap.com/dev/key/app
AMAP_KEY=

# 和风天气 Key（空气质量，优先于彩云）
# https://dev.qweather.com/
# 控制台创建项目后复制 KEY；Host 默认 devapi.qweather.com
# 若控制台给了专属 API Host，填到 QWEATHER_HOST（可带 https://）
QWEATHER_KEY=
# QWEATHER_HOST=https://devapi.qweather.com
# 兼容旧名：HEWEATHER_KEY=

# 彩云天气 Token（空气质量备用）
# https://dashboard.caiyunapp.com/
CAIYUN_TOKEN=

# WAQI Token（备用 AQI；可用 demo）
# https://aqicn.org/data-platform/token/
WAQI_TOKEN=demo

# 每日上游 API 调用上限（默认 200；0 或负数 = 不限制）
# 多实例 Edge 各自计数，属 best-effort
DAILY_API_LIMIT=200

# ------------------------------------------------------------
# 说明：
# 1. 前端只请求同源 /api/*，密钥永不进浏览器包。
# 2. 本地：Vite 开发/预览代理读取本文件注入。
# 3. Vercel / Cloudflare：在控制台写入
#    AMAP_KEY / QWEATHER_KEY / CAIYUN_TOKEN / WAQI_TOKEN / DAILY_API_LIMIT
#    （可选 QWEATHER_HOST）Production + Preview 都要配。
# 4. 空气优先级：和风 → 彩云 → WAQI → Open-Meteo
# 5. 城市展示名：公开逆地理（BigDataCloud / Open-Meteo），无手写字典
# 6. 切勿把真实 key 写进 README、截图或提交到 git。
# ------------------------------------------------------------
